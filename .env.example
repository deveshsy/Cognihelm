# --- Public Endpoint ---
PUBLIC_API_URL=https://your-ngrok-id.ngrok-free.app

# --- Slack Keys ---
# Found in Slack App > Basic Information > Signing Secret
SLACK_SIGNING_SECRET=your_signing_secret_here

# --- Security (RS256) ---
# Generate with: openssl genrsa -out private.pem 2048
RSA_PRIVATE_KEY_PATH=./private.pem
# Generate with: openssl rsa -in private.pem -pubout -out public.pem
RSA_PUBLIC_KEY_PATH=./public.pem

# --- AWS / DynamoDB ---
AWS_REGION=us-east-1
DYNAMODB_TABLE_NAME=HITL_Tasks

# --- Compliance (Crossmint) ---
CROSSMINT_API_KEY=your_crossmint_key
CROSSMINT_PROJECT_ID=your_project_id
